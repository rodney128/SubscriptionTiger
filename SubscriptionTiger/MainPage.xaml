<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SubscriptionTiger.MainPage"
             Title="SubscriptionTiger"
             BackgroundColor="#111111">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,96" Spacing="12">

            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label Text="SubscriptionTiger"
                       TextColor="#F5C452"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                <Image Source="tigericon.png"
                       WidthRequest="56"
                       HeightRequest="56"
                       HorizontalOptions="Center"
                       Aspect="AspectFit" />
                <Label Text="Find, review, and manage recurring subscriptions."
                       TextColor="#E0E0E0"
                       FontSize="13"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Frame CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Subscription Review"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />

                    <Button Text="Add Sample Subscription"
                            Clicked="OnAddSampleManualClicked"
                            CornerRadius="10"
                            HeightRequest="42"
                            BackgroundColor="#CFAF57"
                            TextColor="Black"
                            FontAttributes="Bold" />

                    <Label Text="Add Manual Subscription"
                           TextColor="#E0E0E0"
                           FontSize="13"
                           FontAttributes="Bold" />

                    <Entry x:Name="ManualVendorEntry"
                           Placeholder="Vendor name"
                           HeightRequest="40"
                           TextColor="#FFFFFF"
                           PlaceholderColor="#9B9B9B"
                           BackgroundColor="#2A2A2A" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               x:Name="ManualPriceEntry"
                               Placeholder="Price"
                               Keyboard="Numeric"
                               HeightRequest="40"
                               TextColor="#FFFFFF"
                               PlaceholderColor="#9B9B9B"
                               BackgroundColor="#2A2A2A" />

                        <Picker Grid.Column="1"
                                x:Name="ManualBillingCyclePicker"
                                Title="Billing"
                                HeightRequest="40"
                                TextColor="#FFFFFF"
                                BackgroundColor="#2A2A2A">
                            <Picker.Items>
                                <x:String>Monthly</x:String>
                                <x:String>Yearly</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <DatePicker x:Name="ManualRenewalDatePicker"
                                HeightRequest="40"
                                TextColor="#FFFFFF"
                                BackgroundColor="#2A2A2A" />

                    <Button Text="Add Manual Subscription"
                            Clicked="OnAddManualSubscriptionClicked"
                            CornerRadius="10"
                            HeightRequest="42"
                            BackgroundColor="#2E3440"
                            TextColor="White"
                            FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Scan Sources"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />

                    <Button Text="Gmail connection pending"
                            Clicked="OnScanGmailClicked"
                            CornerRadius="10"
                            HeightRequest="40"
                            BackgroundColor="#3B4252"
                            TextColor="White"
                            FontAttributes="Bold" />

                    <Button Text="Outlook coming soon"
                            Clicked="OnScanOutlookClicked"
                            CornerRadius="10"
                            HeightRequest="40"
                            BackgroundColor="#2E3440"
                            TextColor="White" />

                    <Button Text="Other email coming soon"
                            Clicked="OnScanOtherEmailClicked"
                            CornerRadius="10"
                            HeightRequest="40"
                            BackgroundColor="#2E3440"
                            TextColor="White" />

                    <Button Text="Bank file coming soon"
                            Clicked="OnScanBankFileClicked"
                            CornerRadius="10"
                            HeightRequest="40"
                            BackgroundColor="#2E3440"
                            TextColor="White" />
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Last Activity"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />

                    <Label x:Name="LastScanResultEmptyState"
                           Text="No activity yet."
                           TextColor="#B0B0B0"
                           FontSize="13" />

                    <VerticalStackLayout x:Name="LastScanResultGrid" IsVisible="False" Spacing="2">
                        <Label x:Name="ScanSummarySourceValue" TextColor="#FFFFFF" FontSize="13" FontAttributes="Bold" />
                        <Label x:Name="ScanSummaryResultValue" TextColor="#E0E0E0" FontSize="12" />
                        <Label x:Name="ScanSummaryTimeValue" TextColor="#B0B0B0" FontSize="12" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Suspected Subscriptions"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />
                    <VerticalStackLayout x:Name="SuspectedContainer" Spacing="8" />
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Confirmed Summary"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />
                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="8"
                          RowSpacing="2">
                        <Label Grid.Row="0" Grid.Column="0" Text="Confirmed:" TextColor="#E0E0E0" FontSize="12" />
                        <Label Grid.Row="0" Grid.Column="1" x:Name="ConfirmedSummaryCountValue" TextColor="#FFFFFF" FontSize="12" />

                        <Label Grid.Row="1" Grid.Column="0" Text="Monthly total:" TextColor="#E0E0E0" FontSize="12" />
                        <Label Grid.Row="1" Grid.Column="1" x:Name="ConfirmedSummaryMonthlyTotalValue" TextColor="#FFFFFF" FontSize="12" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Confirmed Subscriptions"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />
                    <VerticalStackLayout x:Name="ConfirmedContainer" Spacing="8" />
                </VerticalStackLayout>
            </Frame>

            <Frame x:Name="MoreOptionsSection" CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Button x:Name="ToggleMoreOptionsButton"
                            Text="Show More Options"
                            Clicked="OnToggleMoreOptionsClicked"
                            CornerRadius="10"
                            HeightRequest="42"
                            BackgroundColor="#2E3440"
                            TextColor="White"
                            FontAttributes="Bold" />

                    <VerticalStackLayout x:Name="MoreOptionsContent" IsVisible="False" Spacing="8">
                        <Button x:Name="ToggleHelpButton"
                                Text="Show Help"
                                Clicked="OnToggleHelpClicked"
                                CornerRadius="10"
                                HeightRequest="42"
                                BackgroundColor="#2E3440"
                                TextColor="White" />

                        <Frame x:Name="HelpSection" IsVisible="False" CornerRadius="10" Padding="10" BackgroundColor="#171717" BorderColor="#3A2E17" HasShadow="False">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Help"
                                       TextColor="#F5C452"
                                       FontAttributes="Bold"
                                       FontSize="16" />
                                <Label Text="SubscriptionTiger helps you review possible recurring subscriptions."
                                       TextColor="#E0E0E0"
                                       FontSize="12" />
                                <Label Text="Use Add Sample Subscription or Add Manual Subscription to test the workflow quickly."
                                       TextColor="#E0E0E0"
                                       FontSize="12" />
                                <Label Text="Gmail connection is pending while native Google authorization setup is completed."
                                       TextColor="#E0E0E0"
                                       FontSize="12" />
                            </VerticalStackLayout>
                        </Frame>

                        <Button x:Name="ToggleDiagnosticsButton"
                                Text="Show Diagnostics / Developer Info"
                                Clicked="OnToggleDiagnosticsClicked"
                                CornerRadius="10"
                                HeightRequest="42"
                                BackgroundColor="#2E3440"
                                TextColor="White" />

                        <Frame x:Name="DiagnosticsSection" IsVisible="False" CornerRadius="10" Padding="10" BackgroundColor="#171717" BorderColor="#3A2E17" HasShadow="False">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Diagnostics"
                                       TextColor="#F5C452"
                                       FontAttributes="Bold"
                                       FontSize="16" />
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Last action:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="0" Grid.Column="1" x:Name="LastActionValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="1" Grid.Column="0" Text="Last scan status:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="1" Grid.Column="1" x:Name="LastScanStatusValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="2" Grid.Column="0" Text="Suspected count:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="2" Grid.Column="1" x:Name="SuspectedCountValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="3" Grid.Column="0" Text="Confirmed count:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="3" Grid.Column="1" x:Name="ConfirmedCountValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="4" Grid.Column="0" Text="Gmail OAuth status:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="4" Grid.Column="1" x:Name="GmailOAuthStatusValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="5" Grid.Column="0" Text="Storage status:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="5" Grid.Column="1" x:Name="StorageStatusValue" TextColor="#FFFFFF" FontSize="12" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
