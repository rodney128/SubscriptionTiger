<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SubscriptionTiger.MainPage"
             Title="SubscriptionTiger"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#111111">

    <ScrollView>
        <VerticalStackLayout Padding="16,14,16,96" Spacing="10">

            <VerticalStackLayout Spacing="4" HorizontalOptions="Fill" VerticalOptions="Start">
                <Image Source="tigericon.png"
                       WidthRequest="72"
                       HeightRequest="72"
                       HorizontalOptions="Center"
                       Aspect="AspectFit" />
                <Label Text="SubscriptionTiger"
                       TextColor="#F5C452"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
                <Label Text="Find and manage recurring subscriptions."
                       TextColor="#E0E0E0"
                       FontSize="12"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Frame CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Scan Sources"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />

                    <Label Text="Automatic scanning is being connected."
                           TextColor="#E0E0E0"
                           FontSize="12" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Padding="2,6">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGmailSourceTapped" />
                        </Grid.GestureRecognizers>
                        <Label Text="Gmail" TextColor="#FFFFFF" FontSize="13" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="Pending" TextColor="#F5C452" FontSize="12" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Padding="2,6">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOutlookSourceTapped" />
                        </Grid.GestureRecognizers>
                        <Label Text="Outlook" TextColor="#FFFFFF" FontSize="13" />
                        <Label Grid.Column="1" Text="Coming soon" TextColor="#B0B0B0" FontSize="12" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Padding="2,6">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOtherEmailSourceTapped" />
                        </Grid.GestureRecognizers>
                        <Label Text="Other email" TextColor="#FFFFFF" FontSize="13" />
                        <Label Grid.Column="1" Text="Coming soon" TextColor="#B0B0B0" FontSize="12" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Padding="2,6">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBankFileSourceTapped" />
                        </Grid.GestureRecognizers>
                        <Label Text="Bank file" TextColor="#FFFFFF" FontSize="13" />
                        <Label Grid.Column="1" Text="Coming soon" TextColor="#B0B0B0" FontSize="12" />
                    </Grid>

                    <Button x:Name="ToggleManualEntryButton"
                            Text="Add Subscription Manually"
                            Clicked="OnToggleManualEntryClicked"
                            CornerRadius="10"
                            HeightRequest="42"
                            BackgroundColor="#2E3440"
                            TextColor="White"
                            FontAttributes="Bold" />

                    <VerticalStackLayout x:Name="ManualEntryPanel" IsVisible="False" Spacing="8">
                        <Entry x:Name="ManualVendorEntry"
                               Placeholder="Vendor name"
                               HeightRequest="40"
                               TextColor="#FFFFFF"
                               PlaceholderColor="#9B9B9B"
                               BackgroundColor="#2A2A2A" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   x:Name="ManualPriceEntry"
                                   Placeholder="Amount"
                                   Keyboard="Numeric"
                                   HeightRequest="40"
                                   TextColor="#FFFFFF"
                                   PlaceholderColor="#9B9B9B"
                                   BackgroundColor="#2A2A2A" />

                            <Picker Grid.Column="1"
                                    x:Name="ManualBillingCyclePicker"
                                    Title="Billing"
                                    HeightRequest="40"
                                    TextColor="#FFFFFF"
                                    BackgroundColor="#2A2A2A">
                                <Picker.Items>
                                    <x:String>Monthly</x:String>
                                    <x:String>Yearly</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>

                        <DatePicker x:Name="ManualRenewalDatePicker"
                                    HeightRequest="40"
                                    TextColor="#FFFFFF"
                                    BackgroundColor="#2A2A2A" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Text="Save Manual Subscription"
                                    Clicked="OnAddManualSubscriptionClicked"
                                    CornerRadius="10"
                                    HeightRequest="40"
                                    BackgroundColor="#CFAF57"
                                    TextColor="Black"
                                    FontAttributes="Bold" />

                            <Button Grid.Column="1"
                                    Text="Cancel Manual Entry"
                                    Clicked="OnCancelManualEntryClicked"
                                    CornerRadius="10"
                                    HeightRequest="40"
                                    BackgroundColor="#2E3440"
                                    TextColor="White" />
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Review Summary"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto"
                          ColumnSpacing="8"
                          RowSpacing="2">
                        <Label Grid.Row="0" Grid.Column="0" Text="Estimated monthly total:" TextColor="#E0E0E0" FontSize="12" />
                        <Label Grid.Row="0" Grid.Column="1" x:Name="ConfirmedSummaryMonthlyTotalValue" TextColor="#FFFFFF" FontSize="12" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                        <Button Grid.Row="0"
                                Grid.ColumnSpan="2"
                                Text="Suspected Subscriptions"
                                Clicked="OnViewSuspectedClicked"
                                CornerRadius="10"
                                HeightRequest="40"
                                HorizontalOptions="Fill"
                                BackgroundColor="#2E3440"
                                TextColor="White" />
                        <Label Grid.Row="0"
                               Grid.Column="1"
                               x:Name="SuspectedReviewCountValue"
                               Text="0"
                               TextColor="#FFFFFF"
                               FontSize="13"
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               HorizontalOptions="End"
                               Margin="0,0,14,0"
                               InputTransparent="True" />

                        <Button Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Text="Confirmed Subscriptions"
                                Clicked="OnViewConfirmedClicked"
                                CornerRadius="10"
                                HeightRequest="40"
                                HorizontalOptions="Fill"
                                BackgroundColor="#2E3440"
                                TextColor="White" />
                        <Label Grid.Row="1"
                               Grid.Column="1"
                               x:Name="ConfirmedReviewCountValue"
                               Text="0"
                               TextColor="#FFFFFF"
                               FontSize="13"
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               HorizontalOptions="End"
                               Margin="0,0,14,0"
                               InputTransparent="True" />
                    </Grid>

                    <Button x:Name="HideReviewButton"
                            Text="Back to Summary"
                            Clicked="OnHideReviewClicked"
                            CornerRadius="10"
                            HeightRequest="40"
                            BackgroundColor="#2E3440"
                            TextColor="White"
                            IsVisible="False" />
                </VerticalStackLayout>
            </Frame>

            <Frame x:Name="SuspectedSectionFrame" CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False" IsVisible="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Suspected Subscriptions"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />
                    <VerticalStackLayout x:Name="SuspectedContainer" Spacing="8" />
                </VerticalStackLayout>
            </Frame>

            <Frame x:Name="ConfirmedSectionFrame" CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False" IsVisible="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Confirmed Subscriptions"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />
                    <VerticalStackLayout x:Name="ConfirmedContainer" Spacing="8" />
                </VerticalStackLayout>
            </Frame>

            <Frame x:Name="MoreOptionsSection" CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Button x:Name="ToggleMoreOptionsButton"
                            Text="Show More Options"
                            Clicked="OnToggleMoreOptionsClicked"
                            CornerRadius="10"
                            HeightRequest="42"
                            BackgroundColor="#2E3440"
                            TextColor="White"
                            FontAttributes="Bold" />

                    <VerticalStackLayout x:Name="MoreOptionsContent" IsVisible="False" Spacing="8">
                        <Button x:Name="ClearTestDataButton"
                                Text="Clear Test Data"
                                Clicked="OnClearTestDataClicked"
                                CornerRadius="10"
                                HeightRequest="42"
                                BackgroundColor="#2E3440"
                                TextColor="White" />

                        <Button x:Name="AddSampleSubscriptionButton"
                                Text="Add Demo Subscription"
                                Clicked="OnAddSampleManualClicked"
                                CornerRadius="10"
                                HeightRequest="42"
                                BackgroundColor="#2E3440"
                                TextColor="White" />

                        <Button x:Name="ToggleHelpButton"
                                Text="Show Help"
                                Clicked="OnToggleHelpClicked"
                                CornerRadius="10"
                                HeightRequest="42"
                                BackgroundColor="#2E3440"
                                TextColor="White" />

                        <Frame x:Name="HelpSection" IsVisible="False" CornerRadius="10" Padding="10" BackgroundColor="#171717" BorderColor="#3A2E17" HasShadow="False">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Help"
                                       TextColor="#F5C452"
                                       FontAttributes="Bold"
                                       FontSize="16" />
                                <Label Text="SubscriptionTiger helps you review recurring subscriptions."
                                       TextColor="#E0E0E0"
                                       FontSize="12" />
                                <Label Text="Use Add Demo Subscription to create test data quickly."
                                       TextColor="#E0E0E0"
                                       FontSize="12" />
                                <Label Text="Use Add Subscription Manually to enter a subscription yourself."
                                       TextColor="#E0E0E0"
                                       FontSize="12" />
                                <Label Text="Gmail connection is pending while Google authorization is being rebuilt."
                                       TextColor="#E0E0E0"
                                       FontSize="12" />
                                <Label Text="Confirm suspected subscriptions you recognize and remove confirmed subscriptions you no longer want tracked."
                                       TextColor="#E0E0E0"
                                       FontSize="12" />
                            </VerticalStackLayout>
                        </Frame>

                        <Button x:Name="ToggleDiagnosticsButton"
                                Text="Show Diagnostics / Developer Info"
                                Clicked="OnToggleDiagnosticsClicked"
                                CornerRadius="10"
                                HeightRequest="42"
                                BackgroundColor="#2E3440"
                                TextColor="White" />

                        <Frame x:Name="DiagnosticsSection" IsVisible="False" CornerRadius="10" Padding="10" BackgroundColor="#171717" BorderColor="#3A2E17" HasShadow="False">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Diagnostics"
                                       TextColor="#F5C452"
                                       FontAttributes="Bold"
                                       FontSize="16" />
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Last action:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="0" Grid.Column="1" x:Name="LastActionValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="1" Grid.Column="0" Text="Last scan status:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="1" Grid.Column="1" x:Name="LastScanStatusValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="2" Grid.Column="0" Text="Suspected count:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="2" Grid.Column="1" x:Name="SuspectedCountValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="3" Grid.Column="0" Text="Confirmed count:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="3" Grid.Column="1" x:Name="ConfirmedCountValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="4" Grid.Column="0" Text="Gmail OAuth status:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="4" Grid.Column="1" x:Name="GmailOAuthStatusValue" TextColor="#FFFFFF" FontSize="12" />

                                    <Label Grid.Row="5" Grid.Column="0" Text="Storage status:" TextColor="#E0E0E0" FontSize="12" />
                                    <Label Grid.Row="5" Grid.Column="1" x:Name="StorageStatusValue" TextColor="#FFFFFF" FontSize="12" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="12" Padding="12" BackgroundColor="#1A1A1A" BorderColor="#3A2E17" HasShadow="False">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Last Activity"
                           TextColor="#F5C452"
                           FontAttributes="Bold"
                           FontSize="17" />

                    <Label x:Name="LastActivityValue"
                           Text="No scan yet."
                           TextColor="#B0B0B0"
                           FontSize="13" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
